# Required
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
OPENAI_API_KEY=

# Optional with defaults
NETWORK_ID=base-sepolia
OPENAI_MODEL=gpt-4o-mini
